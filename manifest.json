// =============================
// manifest.json (MV3)
// =============================
{
  "manifest_version": 3,
  "name": "Artemis Toilet GO/NO-GO Indicator",
  "version": "1.0",
  "description": "Show the GO/NO-GO status of Artemis’ toilet.",
  "permissions": ["activeTab", "scripting", "alarms"],
  "host_permissions": ["https://artemis.cdnspace.ca/*"],
  "action": {
    "default_title": "Artemis Status"
  },
  "background": {
    "service_worker": "background.js"
  }
}